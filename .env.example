# Neo4j Aura
neo4j_uri=neo4j+s://<instance>.databases.neo4j.io
neo4j_username=neo4j
neo4j_password=<password>
neo4j_database=neo4j
aura_instanceid=<instance-id>
aura_instancename=<instance-name>

# Backend CORS (comma-separated). Use your deployed frontend URL(s).
# Example: CORS_ORIGINS=https://soc-frontend.vercel.app,https://soc.example.com
CORS_ORIGINS=

# Optional bridge tuning
# GRAPH_BRIDGE_MATCH_THRESHOLD=0.5
# GRAPH_BRIDGE_MIN_HITS=1

# Optional RAG reranking tuning
# RAG_RERANK_ALPHA=0.7
# RAG_RERANK_TOP_K=5

# ChromaDB persistent directory (set to a mounted volume path in cloud)
# CHROMA_PATH=/data/chroma_db
