        {
          "action": "Change root account password",
          "cli": "# Use AWS Console password reset: https://signin.aws.amazon.com/forgot",
          "priority": "Critical"
        },
        {
          "action": "Contact AWS Support for emergency lockdown",
          "cli": "# Open critical security ticket via AWS Support Center",
          "priority": "Critical"
        },
        {
          "action": "Enable CloudTrail log file validation if not enabled",
          "cli": "aws cloudtrail update-trail --name <TRAIL> --enable-log-file-validation",
