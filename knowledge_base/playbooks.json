  {
    "playbook_id": "IR-DATA-001",
    "name": "Snapshot Sharing / Data Transfer Response",
    "incident_types": ["Data Exfiltration via Snapshots", "Unauthorized Data Sharing", "Cross-Account Data Transfer"],
    "prerequisites": ["CloudTrail enabled", "EBS/RDS snapshot encryption", "AWS Config snapshot tracking"],
    "techniques_addressed": ["T1537"],
    "triage_questions": [
      "Which snapshots or AMIs were shared externally?",
      "What AWS account IDs were granted access to the snapshots?",
      "Was the snapshot made public or shared with specific accounts?",
      "What data exists on the snapshot or AMI that was shared?",
      "Did the user who shared the snapshot have legitimate reasons to do so?"
    ],
    "related_playbooks": ["IR-S3-001", "IR-S3-002"],
    "response_phases": {
      "detection": [
        "Alert on ModifySnapshotAttribute events",
        "Monitor ModifyImageAttribute with public sharing",
        "Track ModifyDBSnapshotAttribute with external accounts",
        "GuardDuty: Exfiltration:S3/ObjectRead.Unusual (for AMI exfil)"
      ],
      "analysis": [
        {
          "step": "Identify shared snapshots",
          "cli": "aws ec2 describe-snapshots --owner-ids self --query 'Snapshots[?CreateVolumePermissions[?Group==`all` || UserId!=null]]'"
        },
        {
          "step": "Check for shared AMIs",
          "cli": "aws ec2 describe-images --owners self --query 'Images[?LaunchPermissions[?Group==`all` || UserId!=null]]'"
        },
        {
          "step": "Review RDS snapshot permissions",
          "cli": "aws rds describe-db-snapshots --snapshot-type manual --query 'DBSnapshots[].DBSnapshotIdentifier' | xargs -I {} aws rds describe-db-snapshot-attributes --db-snapshot-identifier {}"
        },
        {
          "step": "Identify external account IDs",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=ModifySnapshotAttribute | jq '.Events[] | .CloudTrailEvent | fromjson | .requestParameters.createVolumePermission.add.items[].userId'"
        }
      ],
      "containment": [
        {
          "action": "Remove public sharing immediately",
          "cli": "aws ec2 modify-snapshot-attribute --snapshot-id <SNAP_ID> --attribute createVolumePermission --operation-type remove --group-names all",
          "priority": "Critical"
        },
        {
          "action": "Revoke external account permissions",
          "cli": "aws ec2 modify-snapshot-attribute --snapshot-id <SNAP_ID> --attribute createVolumePermission --operation-type remove --user-ids <EXTERNAL_ACCOUNT>",
          "priority": "Critical"
        },
        {
          "action": "Remove AMI sharing",
          "cli": "aws ec2 modify-image-attribute --image-id <AMI_ID> --launch-permission \"Remove=[{UserId=<EXTERNAL_ACCOUNT>}]\"",
          "priority": "Critical"
        },
        {
          "action": "Revoke RDS snapshot sharing",
          "cli": "aws rds modify-db-snapshot-attribute --db-snapshot-identifier <SNAPSHOT> --attribute-name restore --values-to-remove <EXTERNAL_ACCOUNT>",
          "priority": "Critical"
        }
      ],
      "eradication": [
        {
          "action": "Delete compromised snapshots if data exfiltrated",
          "cli": "aws ec2 delete-snapshot --snapshot-id <SNAP_ID>"
        },
        {
          "action": "Deregister exposed AMIs",
          "cli": "aws ec2 deregister-image --image-id <AMI_ID>"
        },
        {
          "action": "Delete RDS snapshots shared externally",
          "cli": "aws rds delete-db-snapshot --db-snapshot-identifier <SNAPSHOT>"
        }
      ],
      "recovery": [
        {
          "action": "Create new encrypted snapshots",
          "cli": "aws ec2 create-snapshot --volume-id <VOL_ID> --description \"Secure snapshot\" --tag-specifications 'ResourceType=snapshot,Tags=[{Key=Encrypted,Value=true}]'"
        },
        {
          "action": "Enforce encryption on all snapshots via SCP",
          "cli": "aws organizations attach-policy --policy-id <FORCE_ENCRYPTION_SCP> --target-id <OU>"
        },
        {
          "action": "Implement AWS Backup for centralized snapshot management",
          "cli": "aws backup create-backup-plan --backup-plan file://encrypted-backup-plan.json"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-DESTRUCT-001",
    "name": "Mass Deletion / Data Destruction Response",
    "incident_types": ["Data Destruction", "Ransomware", "Sabotage", "Resource Termination"],
    "prerequisites": ["CloudTrail enabled", "S3 versioning", "RDS automated backups", "EBS snapshots"],
    "techniques_addressed": ["T1485"],
    "triage_questions": [
      "How many resources were deleted and what types?",
      "What is the timeline of deletion events?",
      "Which user or role performed the mass deletion?",
      "Were the deletions targeted at specific resource types or random?",
      "Are there backups available for the deleted resources?"
    ],
    "related_playbooks": ["IR-IAM-001"],
    "response_phases": {
      "detection": [
        "High volume Delete*/Terminate* events",
        "GuardDuty: Impact:S3/ObjectDelete.Unusual",
        "CloudWatch alarm for deletion rate spike",
        "AWS Config compliance changes"
      ],
      "analysis": [
        {
          "step": "Identify deletion actor and scope",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<ACTOR> | jq '.Events[] | .CloudTrailEvent | fromjson | select(.eventName | startswith(\"Delete\") or startswith(\"Terminate\"))'"
        },
        {
          "step": "List deleted resources",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=DeleteObject --max-items 1000 | jq '.Events[] | .CloudTrailEvent | fromjson | .requestParameters.bucketName, .requestParameters.key'"
        },
        {
          "step": "Check for backup availability",
          "cli": "aws backup list-recovery-points-by-backup-vault --backup-vault-name Default"
        }
      ],
      "containment": [
        {
          "action": "Immediately disable attacker credentials",
          "cli": "aws iam delete-access-key --user-name <ATTACKER> --access-key-id <AKIA...>",
          "priority": "Critical"
        },
        {
          "action": "Apply deny-all policy to remaining resources",
          "cli": "aws iam put-user-policy --user-name <ATTACKER> --policy-name EmergencyDeny --policy-document '{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Deny\",\"Action\":\"*\",\"Resource\":\"*\"}]}'",
          "priority": "Critical"
        },
        {
          "action": "Enable MFA delete on S3 buckets",
          "cli": "aws s3api put-bucket-versioning --bucket <BUCKET> --versioning-configuration Status=Enabled,MFADelete=Enabled --mfa '<SERIAL> <CODE>'",
          "priority": "High"
        },
        {
          "action": "Snapshot remaining resources immediately",
          "cli": "aws ec2 create-snapshot --volume-id <VOL_ID> --description 'Emergency backup'",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Review for other compromised accounts",
          "cli": "aws iam list-users | jq '.Users[] | select(.CreateDate > \"<INCIDENT_START>\")'"
        },
        {
          "action": "Audit for persistence mechanisms",
          "cli": "aws lambda list-functions --query 'Functions[?LastModified>`<INCIDENT_START>`]'"
        }
      ],
      "recovery": [
        {
          "action": "Restore S3 objects from versioning",
          "cli": "aws s3api list-object-versions --bucket <BUCKET> --prefix <PREFIX> | jq -r '.DeleteMarkers[] | \"aws s3api delete-object --bucket <BUCKET> --key \" + .Key + \" --version-id \" + .VersionId' | bash"
        },
        {
          "action": "Restore EC2 instances from snapshots",
          "cli": "aws ec2 create-volume --snapshot-id <SNAP_ID> --availability-zone <AZ>; aws ec2 run-instances --image-id <AMI> --block-device-mappings DeviceName=/dev/xvda,Ebs={VolumeId=<VOL_ID>}"
        },
        {
          "action": "Restore RDS from automated backup",
          "cli": "aws rds restore-db-instance-to-point-in-time --source-db-instance-identifier <SOURCE> --target-db-instance-identifier <TARGET> --restore-time <TIMESTAMP>"
        },
        {
          "action": "Implement S3 Object Lock to prevent future deletion",
          "cli": "aws s3api put-object-lock-configuration --bucket <BUCKET> --object-lock-configuration ObjectLockEnabled=Enabled,Rule={DefaultRetention={Mode=COMPLIANCE,Days=90}}"
        },
        {
          "action": "Enable AWS Backup Vault Lock",
          "cli": "aws backup put-backup-vault-lock-configuration --backup-vault-name <VAULT> --min-retention-days 30"
        }
      ]
    }
  },
