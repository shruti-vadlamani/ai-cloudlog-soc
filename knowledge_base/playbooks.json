    "playbook_id": "IR-LAMBDA-001",
    "name": "Lambda Function Backdoor Response",
    "incident_types": ["Serverless Backdoor", "Data Exfiltration via Lambda", "Unauthorized Function Creation"],
    "prerequisites": ["CloudTrail with Lambda data events", "Lambda function versioning", "X-Ray tracing"],
    "techniques_addressed": ["T1537", "T1078"],
    "triage_questions": [
      "Which Lambda function was created or modified?",
      "What external AWS accounts or principals were granted invocation permissions?",
      "What IAM role is the Lambda function using?",
      "Has the Lambda function been invoked and by whom?",
      "What resources does the Lambda function have access to?"
    ],
    "related_playbooks": ["IR-IAM-002", "IR-DATA-001"],
    "response_phases": {
      "detection": [
        "Alert on CreateFunction from unusual actors",
        "Monitor AddPermission granting external accounts",
        "Track UpdateFunctionCode modifications",
        "GuardDuty: Impact:Runtime/MaliciousIPCaller"
      ],
      "analysis": [
        {
          "step": "List recently created Lambda functions",
          "cli": "aws lambda list-functions --query 'Functions[?LastModified>`<DATE>`]'"
        },
        {
          "step": "Review function resource policies",
          "cli": "aws lambda get-policy --function-name <FUNCTION>"
        },
        {
          "step": "Check function invocation logs",
          "cli": "aws logs filter-log-events --log-group-name /aws/lambda/<FUNCTION> --start-time <TIMESTAMP>"
        },
        {
          "step": "Inspect function code for malicious logic",
          "cli": "aws lambda get-function --function-name <FUNCTION> --query 'Code.Location' | xargs wget -O function.zip"
        }
      ],
      "containment": [
        {
          "action": "Remove external invocation permissions",
          "cli": "aws lambda remove-permission --function-name <FUNCTION> --statement-id <STATEMENT_ID>",
          "priority": "Critical"
        },
        {
          "action": "Delete malicious Lambda function",
          "cli": "aws lambda delete-function --function-name <MALICIOUS_FUNCTION>",
          "priority": "Critical"
        },
        {
          "action": "Revoke IAM role permissions attached to function",
          "cli": "aws iam detach-role-policy --role-name <LAMBDA_ROLE> --policy-arn <OVERLY_PERMISSIVE_POLICY>",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Review all Lambda functions for similar patterns",
          "cli": "aws lambda list-functions | jq -r '.Functions[].FunctionName' | xargs -I {} aws lambda get-policy --function-name {} 2>/dev/null"
        },
        {
          "action": "Audit S3 buckets/DynamoDB tables accessed by function",
          "cli": "aws logs filter-log-events --log-group-name /aws/lambda/<FUNCTION> --filter-pattern '[time, request_id, event_type, ...] event_type=~\"s3\" || event_type=~\"dynamodb\"'"
        }
      ],
      "recovery": [
        {
          "action": "Restore legitimate function from previous version",
          "cli": "aws lambda publish-version --function-name <FUNCTION> --code-sha-256 <KNOWN_GOOD_SHA>"
        },
        {
          "action": "Implement function URL authentication",
          "cli": "aws lambda update-function-url-config --function-name <FUNCTION> --auth-type AWS_IAM"
        },
        {
          "action": "Enable resource-based policy restrictions via SCP",
          "cli": "aws organizations attach-policy --policy-id <LAMBDA_RESTRICTION_SCP> --target-id <OU>"
        }
      ]
    }
  }
