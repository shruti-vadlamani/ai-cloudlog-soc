        "Unusual read-only operations from non-security accounts",
        "Sequential service enumeration pattern"
      ],
      "analysis": [
        {
          "step": "Identify enumeration actor",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<SUSPECT> --max-items 1000 | jq '.Events[] | .CloudTrailEvent | fromjson | select(.eventName | startswith(\"List\") or startswith(\"Describe\"))'"
        },
        {
          "step": "Count unique services enumerated",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<SUSPECT> | jq '[.Events[] | .CloudTrailEvent | fromjson | .eventSource] | unique | length'"
        },
        {
          "step": "Check for privileged enumeration (GetAccountAuthorizationDetails)",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=GetAccountAuthorizationDetails"
        }
      ],
      "containment": [
        {
          "action": "Deactivate enumeration credentials",
          "cli": "aws iam update-access-key --user-name <SUSPECT> --access-key-id <AKIA...> --status Inactive",
          "priority": "High"
        },
        {
          "action": "Apply rate limiting via SCPs if org-level",
          "cli": "# Implement quota management policies"
        },
        {
          "action": "Monitor for follow-on attacks",
          "cli": "aws cloudwatch put-metric-alarm --alarm-name HighAPICalls --metric-name CallCount --namespace AWS/Usage --statistic Sum --period 300 --threshold 1000 --comparison-operator GreaterThanThreshold"
        }
      ],
      "eradication": [
        {
          "action": "Delete compromised access keys",
          "cli": "aws iam delete-access-key --user-name <SUSPECT> --access-key-id <AKIA...>"
