        {
          "action": "Rotate all IAM user credentials as precaution",
          "cli": "# Script to rotate all user keys"
        },
        {
          "action": "Check for billing changes or resource creation",
          "cli": "aws ce get-cost-and-usage --time-period Start=<DATE>,End=<DATE> --granularity DAILY --metrics BlendedCost"
        }
      ],
      "recovery": [
        {
          "action": "Set up new hardware MFA for root account",
          "cli": "# Use AWS Console to configure hardware MFA device"
        },
        {
          "action": "Document root account credentials in secure offline storage",
          "cli": "# Store in physical safe with executive access only"
        },
        {
          "action": "Implement Service Control Policies to restrict root",
          "cli": "aws organizations attach-policy --policy-id <ROOT_RESTRICTION_SCP> --target-id <ROOT_OU>"
        },
        {
          "action": "Set up GuardDuty for continuous monitoring",
          "cli": "aws guardduty create-detector --enable --finding-publishing-frequency FIFTEEN_MINUTES"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-S3-001",
    "name": "S3 Data Exfiltration Response",
    "incident_types": ["Data Breach", "Mass Data Download", "Unauthorized Data Access"],
    "prerequisites": ["S3 Data Events enabled in CloudTrail", "S3 Access Logging", "GuardDuty S3 Protection"],
    "techniques_addressed": ["T1530", "T1619"],    "triage_questions": [
      "Which S3 buckets experienced unusual GetObject activity?",
      "What is the total data volume transferred during the incident window?",
      "Is the source IP address associated with known cloud services or VPNs?",
      "Does the user normally access this S3 bucket with this volume?",
      "Were any bucket policies or ACLs modified before the data access?"
    ],
    "related_playbooks": ["IR-S3-002", "IR-DATA-001"],    "response_phases": {
      "detection": [
        "GuardDuty finding: Exfiltration:S3/ObjectRead.Unusual",
        "High volume GetObject requests in short time",
        "CloudWatch Alarm for S3 data transfer out",
        "Unusual source IPs accessing sensitive buckets"
      ],
      "analysis": [
        {
          "step": "Identify which buckets were accessed",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=GetObject --max-items 500"
        },
        {
          "step": "Check total objects accessed by suspect identity",
          "cli": "aws s3api list-objects-v2 --bucket <BUCKET> --query 'Contents[?LastModified>=`<TIMESTAMP>`]'"
        },
        {
          "step": "Review S3 access logs for detailed timeline",
          "cli": "aws s3 cp s3://<LOG_BUCKET>/<PREFIX>/ . --recursive; grep <SUSPECT_IP> *.log"
        },
        {
          "step": "Determine data sensitivity and volume",
          "cli": "aws s3 ls s3://<BUCKET>/<PREFIX> --recursive --summarize"
        }
      ],
      "containment": [
        {
          "action": "Block public access immediately if enabled",
          "cli": "aws s3api put-public-access-block --bucket <BUCKET> --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true",
          "priority": "Critical"
        },
        {
          "action": "Apply deny bucket policy to suspect principal",
          "cli": "aws s3api put-bucket-policy --bucket <BUCKET> --policy '{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Deny\",\"Principal\":{\"AWS\":\"<SUSPECT_ARN>\"},\"Action\":\"s3:*\",\"Resource\":\"arn:aws:s3:::<BUCKET>/*\"}]}'",
          "priority": "Critical"
        },
        {
          "action": "Deactivate compromised credentials",
          "cli": "aws iam update-access-key --user-name <SUSPECT_USER> --access-key-id <AKIA...> --status Inactive",
          "priority": "Critical"
        },
        {
          "action": "Enable MFA delete if not already set",
          "cli": "aws s3api put-bucket-versioning --bucket <BUCKET> --versioning-configuration Status=Enabled,MFADelete=Enabled --mfa '<MFA_SERIAL> <MFA_CODE>'",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Delete compromised access keys permanently",
          "cli": "aws iam delete-access-key --user-name <SUSPECT_USER> --access-key-id <AKIA...>"
        },
        {
          "action": "Review and remove any bucket policy backdoors",
          "cli": "aws s3api get-bucket-policy --bucket <BUCKET>; aws s3api delete-bucket-policy --bucket <BUCKET>"
        },
        {
          "action": "Remove ACLs granting external access",
          "cli": "aws s3api put-bucket-acl --bucket <BUCKET> --acl private"
        }
      ],
      "recovery": [
        {
          "action": "Restore secure bucket policy",
          "cli": "aws s3api put-bucket-policy --bucket <BUCKET> --policy file://secure-bucket-policy.json"
        },
        {
          "action": "Enable S3 Object Lock for critical data",
          "cli": "aws s3api put-object-lock-configuration --bucket <BUCKET> --object-lock-configuration ObjectLockEnabled=Enabled,Rule={DefaultRetention={Mode=GOVERNANCE,Days=30}}"
        },
        {
          "action": "Implement S3 Access Points for granular control",
          "cli": "aws s3control create-access-point --account-id <ACCOUNT> --name secure-ap --bucket <BUCKET> --vpc-configuration VpcId=<VPC>"
        },
        {
          "action": "Enable CloudWatch metrics for ongoing monitoring",
          "cli": "aws s3api put-bucket-metrics-configuration --bucket <BUCKET> --id EntireBucket --metrics-configuration Id=EntireBucket"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-S3-002",
    "name": "S3 Bucket Policy Tampering Response",
    "incident_types": ["Bucket Exposure", "Data Sharing to External Accounts", "Persistence via Policy"],
    "prerequisites": ["CloudTrail enabled", "S3 bucket versioning", "AWS Config S3 bucket logging"],
    "techniques_addressed": ["T1537"],
    "triage_questions": [
      "What bucket policy changes were made and by whom?",
      "Was the bucket made public or shared with external AWS accounts?",
      "Has there been any GetObject activity from external IPs after the policy change?",
      "What sensitive data classification does this bucket contain?",
      "Were there any PutBucketPolicy or PutBucketAcl events before suspicious access?"
    ],
    "related_playbooks": ["IR-S3-001", "IR-DATA-001"],
    "response_phases": {
      "detection": [
        "Alert on PutBucketPolicy events",
        "Monitor PutBucketAcl with public grants",
        "AWS Config rule: s3-bucket-public-read-prohibited",
        "GuardDuty: Policy:S3/BucketAnonymousAccessGranted"
      ],
      "analysis": [
        {
          "step": "Identify modified bucket policies",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=PutBucketPolicy --max-items 100"
        },
        {
          "step": "Review current bucket policy",
          "cli": "aws s3api get-bucket-policy --bucket <BUCKET> --output text > current-policy.json"
        },
        {
          "step": "Check for external account IDs",
          "cli": "cat current-policy.json | jq '.Statement[] | select(.Principal.AWS | type == \"array\" or type == \"string\") | .Principal.AWS'"
        },
        {
          "step": "Verify bucket ACL for public access",
          "cli": "aws s3api get-bucket-acl --bucket <BUCKET>"
        }
      ],
      "containment": [
        {
          "action": "Delete risky bucket policy immediately",
          "cli": "aws s3api delete-bucket-policy --bucket <BUCKET>",
          "priority": "Critical"
        },
        {
          "action": "Block all public access",
          "cli": "aws s3api put-public-access-block --bucket <BUCKET> --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true",
          "priority": "Critical"
        },
        {
          "action": "Revoke external account access",
          "cli": "aws s3api put-bucket-acl --bucket <BUCKET> --acl private",
          "priority": "Critical"
        }
      ],
      "eradication": [
        {
          "action": "Review CloudTrail for other modified buckets",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=PutBucketPolicy --start-time <DATE> | jq '.Events[] | .CloudTrailEvent | fromjson | .requestParameters.bucketName' | sort -u"
        },
        {
          "action": "Disable compromised credentials",
          "cli": "aws iam delete-access-key --user-name <ATTACKER_USER> --access-key-id <AKIA...>"
        }
      ],
      "recovery": [
        {
          "action": "Restore approved bucket policy from baseline",
          "cli": "aws s3api put-bucket-policy --bucket <BUCKET> --policy file://baseline-bucket-policy.json"
        },
        {
          "action": "Enable S3 Bucket Keys for encryption",
          "cli": "aws s3api put-bucket-encryption --bucket <BUCKET> --server-side-encryption-configuration '{\"Rules\":[{\"ApplyServerSideEncryptionByDefault\":{\"SSEAlgorithm\":\"aws:kms\",\"KMSMasterKeyID\":\"<KMS_KEY>\"}}]}'"
        },
        {
          "action": "Implement SCPs to prevent public buckets org-wide",
          "cli": "aws organizations attach-policy --policy-id <PREVENT_PUBLIC_S3_SCP> --target-id <ROOT_OU>"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-EC2-001",
    "name": "Security Group Tampering Response",
    "incident_types": ["Firewall Rule Bypass", "Unauthorized Network Access", "Lateral Movement Setup"],
    "prerequisites": ["CloudTrail enabled", "VPC Flow Logs", "AWS Config tracking security groups"],
    "techniques_addressed": ["T1578"],
    "triage_questions": [
      "Which security group was modified and what ports were opened?",
      "Who performed the AuthorizeSecurityGroupIngress action?",
      "What EC2 instances are attached to this security group?",
      "Has there been any SSH or RDP connection attempts from the internet after the change?",
      "Was this security group change part of an approved change request?"
    ],
    "related_playbooks": ["IR-IAM-002"],
    "response_phases": {
      "detection": [
        "Alert on AuthorizeSecurityGroupIngress with 0.0.0.0/0",
        "Monitor changes to SSH/RDP ports (22, 3389)",
        "AWS Config rule: restricted-ssh / restricted-common-ports",
        "GuardDuty: Recon:EC2/PortProbeUnprotectedPort"
      ],
      "analysis": [
        {
          "step": "Identify modified security groups",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=AuthorizeSecurityGroupIngress --max-items 50"
        },
        {
          "step": "Review current security group rules",
          "cli": "aws ec2 describe-security-groups --group-ids <SG_ID>"
        },
        {
          "step": "Identify instances using compromised security group",
          "cli": "aws ec2 describe-instances --filters Name=instance.group-id,Values=<SG_ID> --query 'Reservations[].Instances[].[InstanceId,PrivateIpAddress,PublicIpAddress]'"
        },
        {
          "step": "Check VPC Flow Logs for connection attempts",
          "cli": "aws logs filter-log-events --log-group-name /aws/vpc/flowlogs --filter-pattern '[srcIP, dstPort=22 || dstPort=3389]' --start-time <TIMESTAMP>"
        }
      ],
      "containment": [
        {
          "action": "Revoke dangerous ingress rule immediately",
          "cli": "aws ec2 revoke-security-group-ingress --group-id <SG_ID> --ip-permissions IpProtocol=tcp,FromPort=22,ToPort=22,IpRanges='[{CidrIp=0.0.0.0/0}]'",
          "priority": "Critical"
        },
        {
          "action": "Apply restrictive NACL to subnet as additional layer",
          "cli": "aws ec2 create-network-acl-entry --network-acl-id <NACL_ID> --rule-number 100 --protocol tcp --port-range From=22,To=22 --cidr-block 0.0.0.0/0 --egress false --rule-action deny",
          "priority": "High"
        },
        {
          "action": "Isolate compromised instances",
          "cli": "aws ec2 modify-instance-attribute --instance-id <INSTANCE_ID> --groups <QUARANTINE_SG_ID>",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Review instances for compromise indicators",
          "cli": "aws ssm send-command --instance-ids <INSTANCE_ID> --document-name AWS-RunShellScript --parameters 'commands=[\"last -f /var/log/wtmp\",\"cat /var/log/auth.log | grep Accepted\"]'"
        },
        {
          "action": "Terminate compromised instances if needed",
          "cli": "aws ec2 terminate-instances --instance-ids <COMPROMISED_INSTANCE>"
        },
        {
          "action": "Delete attacker-created security groups",
          "cli": "aws ec2 delete-security-group --group-id <MALICIOUS_SG>"
        }
      ],
      "recovery": [
        {
          "action": "Restore security group to baseline configuration",
          "cli": "aws ec2 authorize-security-group-ingress --group-id <SG_ID> --ip-permissions file://baseline-sg-rules.json"
        },
        {
          "action": "Launch replacement instances from clean AMIs",
          "cli": "aws ec2 run-instances --image-id <CLEAN_AMI> --instance-type t3.medium --security-group-ids <SECURE_SG> --subnet-id <SUBNET>"
        },
        {
          "action": "Implement AWS Firewall Manager for centralized SG management",
          "cli": "aws fms put-policy --policy file://centralized-sg-policy.json"
        }
      ]
    }
  },
