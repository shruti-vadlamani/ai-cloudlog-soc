[
  {
    "playbook_id": "IR-IAM-001",
    "name": "Compromised Credentials - Initial Response",
    "incident_types": ["Credential Compromise", "Unauthorized Access", "Brute Force Success"],
    "prerequisites": ["CloudTrail enabled and logging", "AWS CLI configured", "Incident response IAM role"],
    "techniques_addressed": ["T1078", "T1110"],
    "triage_questions": [
      "What is the source IP address of the suspicious login?",
      "Has this user logged in from this geographic location before?",
      "What resources did the user access immediately after authentication?",
      "Were there any failed login attempts from the same IP before success?",
      "What time did the suspicious activity begin and does it match user's normal working hours?"
    ],
    "related_playbooks": ["IR-IAM-002", "IR-IAM-004", "IR-ENUM-001"],
    "response_phases": {
      "detection": [
        "Monitor GuardDuty findings for UnauthorizedAccess:IAMUser",
        "Check for impossible travel or TOR exit node logins",
        "Review failed authentication attempts followed by success",
        "Verify MFA status and unusual login patterns"
      ],
      "analysis": [
        {
          "step": "Identify compromised identity",
          "cli": "aws sts get-caller-identity"
        },
        {
          "step": "Review all API calls by compromised credentials",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<COMPROMISED_USER> --start-time <TIME> --max-items 200"
        },
        {
          "step": "Check for access key usage",
          "cli": "aws iam list-access-keys --user-name <COMPROMISED_USER>"
        },
        {
          "step": "Identify affected resources and permissions",
          "cli": "aws iam list-attached-user-policies --user-name <COMPROMISED_USER>"
        }
      ],
      "containment": [
        {
          "action": "Disable all access keys immediately",
          "cli": "aws iam update-access-key --user-name <COMPROMISED_USER> --access-key-id <AKIA...> --status Inactive",
          "priority": "Critical"
        },
        {
          "action": "Reset console password and force MFA",
          "cli": "aws iam update-login-profile --user-name <COMPROMISED_USER> --password <RANDOM_STRONG> --password-reset-required",
          "priority": "Critical"
        },
        {
          "action": "Revoke all active sessions",
          "cli": "aws iam attach-user-policy --user-name <COMPROMISED_USER> --policy-arn arn:aws:iam::aws:policy/AWSDenyAll",
          "priority": "Critical"
        },
        {
          "action": "Block source IP in AWS WAF or Security Groups",
          "cli": "aws wafv2 update-ip-set --name BlockedIPs --id <ID> --scope REGIONAL --addresses <MALICIOUS_IP>/32",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Delete unauthorized access keys",
          "cli": "aws iam delete-access-key --user-name <COMPROMISED_USER> --access-key-id <AKIA...>"
        },
        {
          "action": "Remove unauthorized policy attachments",
          "cli": "aws iam detach-user-policy --user-name <COMPROMISED_USER> --policy-arn <UNAUTHORIZED_POLICY_ARN>"
        },
        {
          "action": "Delete resources created by attacker",
          "cli": "aws ec2 terminate-instances --instance-ids <MALICIOUS_INSTANCES>"
        },
        {
          "action": "Remove backdoor IAM users if created",
          "cli": "aws iam delete-user --user-name <BACKDOOR_USER>"
        }
      ],
      "recovery": [
        {
          "action": "Generate new access keys with rotation",
          "cli": "aws iam create-access-key --user-name <COMPROMISED_USER>"
        },
        {
          "action": "Re-enable MFA enforcement",
          "cli": "aws iam enable-mfa-device --user-name <COMPROMISED_USER> --serial-number <MFA_ARN> --authentication-code-1 <CODE1> --authentication-code-2 <CODE2>"
        },
        {
          "action": "Restore legitimate policies",
          "cli": "aws iam attach-user-policy --user-name <COMPROMISED_USER> --policy-arn <LEGITIMATE_POLICY>"
        },
        {
          "action": "Monitor for 72 hours post-incident",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<COMPROMISED_USER> --start-time <NOW>"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-IAM-002",
    "name": "IAM Privilege Escalation Response",
    "incident_types": ["Privilege Escalation", "Account Manipulation", "Persistence"],
    "prerequisites": ["CloudTrail enabled", "Config enabled for IAM tracking", "SCPs in place"],
    "techniques_addressed": ["T1098", "T1136", "T1199"],
    "triage_questions": [
      "What IAM permissions were added or modified during the incident window?",
      "Which user performed the privilege escalation actions?",
      "Were any new IAM users roles or policies created?",
      "What is the timeline of IAM write events leading to elevated privileges?",
      "Has the user who escalated privileges accessed sensitive resources afterward?"
    ],
    "related_playbooks": ["IR-IAM-001", "IR-IAM-003"],
    "response_phases": {
      "detection": [
        "Alert on AttachUserPolicy/AttachRolePolicy with AdministratorAccess",
        "Monitor CreateAccessKey events",
        "Track UpdateAssumeRolePolicy modifications",
        "Watch for privilege grants outside change windows"
      ],
      "analysis": [
        {
          "step": "Identify who made privilege change",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=AttachUserPolicy --max-items 50"
        },
        {
          "step": "Review current user permissions",
          "cli": "aws iam get-user-policy --user-name <TARGET_USER> --policy-name <POLICY>"
        },
        {
          "step": "List all attached policies",
          "cli": "aws iam list-attached-user-policies --user-name <TARGET_USER>"
        },
        {
          "step": "Check for newly created access keys",
          "cli": "aws iam list-access-keys --user-name <TARGET_USER>"
        },
        {
          "step": "Review AWS Config timeline for IAM changes",
          "cli": "aws configservice get-resource-config-history --resource-type AWS::IAM::User --resource-id <TARGET_USER> --limit 20"
        }
      ],
      "containment": [
        {
          "action": "Immediately detach administrative policies",
          "cli": "aws iam detach-user-policy --user-name <TARGET_USER> --policy-arn arn:aws:iam::aws:policy/AdministratorAccess",
          "priority": "Critical"
        },
        {
          "action": "Deactivate suspicious access keys",
          "cli": "aws iam update-access-key --user-name <TARGET_USER> --access-key-id <AKIA...> --status Inactive",
          "priority": "Critical"
        },
        {
          "action": "Apply deny-all policy temporarily",
          "cli": "aws iam put-user-policy --user-name <TARGET_USER> --policy-name EmergencyDeny --policy-document '{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Deny\",\"Action\":\"*\",\"Resource\":\"*\"}]}'",
          "priority": "Critical"
        },
        {
          "action": "Revoke assumed role sessions if applicable",
          "cli": "aws iam update-role --role-name <ROLE> --max-session-duration 3600",
          "priority": "High"
        }
      ],
      "eradication": [
        {
          "action": "Delete all unauthorized access keys",
          "cli": "aws iam delete-access-key --user-name <TARGET_USER> --access-key-id <AKIA...>"
        },
        {
          "action": "Remove inline policies added by attacker",
          "cli": "aws iam delete-user-policy --user-name <TARGET_USER> --policy-name <MALICIOUS_POLICY>"
        },
        {
          "action": "Revert trust policy changes on roles",
          "cli": "aws iam update-assume-role-policy --role-name <ROLE> --policy-document file://original-trust-policy.json"
        },
        {
          "action": "Delete backdoor IAM users",
          "cli": "aws iam delete-login-profile --user-name <BACKDOOR_USER>; aws iam delete-user --user-name <BACKDOOR_USER>"
        }
      ],
      "recovery": [
        {
          "action": "Restore legitimate permissions from baseline",
          "cli": "aws iam attach-user-policy --user-name <TARGET_USER> --policy-arn <BASELINE_POLICY_ARN>"
        },
        {
          "action": "Enable enhanced monitoring",
          "cli": "aws cloudtrail put-event-selectors --trail-name main --event-selectors ReadWriteType=All,IncludeManagementEvents=true"
        },
        {
          "action": "Implement SCPs to prevent recurrence",
          "cli": "aws organizations attach-policy --policy-id <PREVENTIVE_SCP> --target-id <OU_ID>"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-IAM-003",
    "name": "MFA Tampering / Authentication Bypass",
    "incident_types": ["MFA Deactivation", "Authentication Process Modification"],
    "prerequisites": ["CloudTrail enabled", "MFA enforcement policies", "IAM audit logs"],
    "techniques_addressed": ["T1556"],
    "triage_questions": [
      "Which MFA device was deactivated or deleted?",
      "Who performed the MFA deactivation action?",
      "Has the affected user account been accessed after MFA removal?",
      "Were there any subsequent authentication attempts without MFA?",
      "What other IAM security changes occurred around the same time?"
    ],
    "related_playbooks": ["IR-IAM-001", "IR-IAM-002"],
    "response_phases": {
      "detection": [
        "Alert on DeactivateMFADevice events",
        "Monitor DeleteVirtualMFADevice calls",
        "Track UpdateSAMLProvider modifications",
        "Watch for MFA policy changes"
      ],
      "analysis": [
        {
          "step": "Identify who deactivated MFA",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=DeactivateMFADevice"
        },
        {
          "step": "Check MFA status for affected users",
          "cli": "aws iam list-mfa-devices --user-name <AFFECTED_USER>"
        },
        {
          "step": "Review subsequent login attempts",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=EventName,AttributeValue=ConsoleLogin --start-time <AFTER_DEACTIVATION>"
        }
      ],
      "containment": [
        {
          "action": "Force logout and disable console access",
          "cli": "aws iam delete-login-profile --user-name <AFFECTED_USER>",
          "priority": "Critical"
        },
        {
          "action": "Deactivate all access keys",
          "cli": "aws iam update-access-key --user-name <AFFECTED_USER> --access-key-id <AKIA...> --status Inactive",
          "priority": "Critical"
        },
        {
          "action": "Apply temporary deny-all policy",
          "cli": "aws iam put-user-policy --user-name <AFFECTED_USER> --policy-name EmergencyBlock --policy-document '{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Deny\",\"Action\":\"*\",\"Resource\":\"*\"}]}'",
          "priority": "Critical"
        }
      ],
      "eradication": [
        {
          "action": "Investigate if attacker obtained access",
          "cli": "aws cloudtrail lookup-events --lookup-attributes AttributeKey=Username,AttributeValue=<AFFECTED_USER> --start-time <AFTER_MFA_REMOVAL>"
        },
        {
          "action": "Remove any unauthorized changes made during window",
          "cli": "# Review and revert specific changes based on analysis"
        }
      ],
      "recovery": [
        {
          "action": "Re-enable MFA with new device",
          "cli": "aws iam create-virtual-mfa-device --virtual-mfa-device-name <USER>-mfa --outfile /tmp/qr-code.png --bootstrap-method QRCodePNG"
        },
        {
          "action": "Enable MFA device for user",
          "cli": "aws iam enable-mfa-device --user-name <AFFECTED_USER> --serial-number <MFA_ARN> --authentication-code-1 <CODE1> --authentication-code-2 <CODE2>"
        },
        {
          "action": "Restore console access with forced MFA",
          "cli": "aws iam create-login-profile --user-name <AFFECTED_USER> --password <TEMP_PASSWORD> --password-reset-required"
        },
        {
          "action": "Enforce MFA via IAM policy",
          "cli": "aws iam put-user-policy --user-name <AFFECTED_USER> --policy-name ForceMFA --policy-document file://force-mfa-policy.json"
        }
      ]
    }
  },
  {
    "playbook_id": "IR-IAM-004",
    "name": "Root Account Compromise",
    "incident_types": ["Root Account Usage", "Highest Privilege Compromise"],
    "prerequisites": ["CloudTrail in separate account", "Root account MFA", "AWS Support access"],
    "techniques_addressed": ["T1078"],
    "triage_questions": [
      "What is the user's typical geographic login location?",
      "What is the distance and time difference between the two login locations?",
      "Are both sessions still active or has one terminated?",
      "What resources were accessed from each geographic location?",
      "Does the UserAgent string differ between the two sessions?"
    ],
    "related_playbooks": ["IR-IAM-001", "IR-IAM-003"],
    "response_phases": {
      "detection": [
        "Alert on any root account API calls",
        "Monitor root account console logins",
